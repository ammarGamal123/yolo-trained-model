{
  "Detection": {
    "ModelPath": "../models/detector_v4.onnx",
    "ClassLabels": ["soap", "soap-cover", "bottle"],
    "ModelWidth": 640,
    "ModelHeight": 640,
    "ConfidenceThreshold": 0.50,
    "IouThreshold": 0.50,
    "CameraIndex": 0,
    "WindowTitle": "Object Detection (ESC to exit)",
    "DefaultImagePath": "../models/test/img.jpg",
    "OutputFileName": "output.jpg",
    "AutoOpenOutput": true,
    "DisplayWidth": 960,
    "DisplayHeight": 540,
    "UseSoftNms": true,
    "SoftNmsSigma": 0.5,
    "MergeCloseDetections": true,
    "MergeDistanceThreshold": 30.0
  }
}
